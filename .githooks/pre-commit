#!/usr/bin/env bash
set -euo pipefail

files=()
while IFS= read -r file; do
  files+=("$file")
done < <(git diff --cached --name-only --diff-filter=ACMR -- '*.md')

if [ ${#files[@]} -eq 0 ]; then
  exit 0
fi

printf -v markdown_files '%q ' "${files[@]}"
make markdownlint MARKDOWNLINT_FILES="$markdown_files"
